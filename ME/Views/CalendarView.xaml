<UserControl x:Class="ME.Views.CalendarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             IsVisibleChanged="CalendarView_IsVisibleChanged">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="280" />
        </Grid.ColumnDefinitions>

        <!-- Calendar -->
        <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,8,0" Padding="12">
            <DockPanel>
                <!-- Month Navigation -->
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                    <Button Content="◀" Click="PrevMonth_Click" Style="{StaticResource SecondaryButtonStyle}"
                            Padding="8,4" DockPanel.Dock="Left" FontSize="12" />
                    <Button Content="▶" Click="NextMonth_Click" Style="{StaticResource SecondaryButtonStyle}"
                            Padding="8,4" DockPanel.Dock="Right" FontSize="12" />
                    <TextBlock x:Name="MonthTitle" FontSize="15" FontWeight="Bold"
                               Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </DockPanel>

                <!-- Weekday Headers -->
                <UniformGrid DockPanel.Dock="Top" Columns="7" Margin="0,0,0,6">
                    <TextBlock Text="日" FontSize="11" Foreground="{DynamicResource AccentRedBrush}" HorizontalAlignment="Center" />
                    <TextBlock Text="一" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center" />
                    <TextBlock Text="二" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center" />
                    <TextBlock Text="三" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center" />
                    <TextBlock Text="四" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center" />
                    <TextBlock Text="五" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center" />
                    <TextBlock Text="六" FontSize="11" Foreground="{DynamicResource AccentRedBrush}" HorizontalAlignment="Center" />
                </UniformGrid>

                <!-- Calendar Grid -->
                <ItemsControl x:Name="CalendarGrid">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="7" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="2" Cursor="Hand" MouseLeftButtonDown="Day_Click"
                                    MinHeight="50" CornerRadius="6"
                                    Background="{Binding CellBackground}"
                                    BorderBrush="{Binding CellBorder}"
                                    BorderThickness="1">
                                <StackPanel Margin="4">
                                    <!-- Day number circle -->
                                    <Border Width="24" Height="24" CornerRadius="12"
                                            Background="{Binding DayBackground}"
                                            HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding Day}" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{Binding DayForeground}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <!-- Task bars -->
                                    <ItemsControl ItemsSource="{Binding Tasks}" Margin="0,2,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Height="12" CornerRadius="2" Margin="0,1"
                                                        Background="{Binding Color}" Opacity="{Binding Opacity}"
                                                        IsHitTestVisible="False">
                                                    <TextBlock Text="{Binding Title}" FontSize="7" Foreground="White"
                                                               Margin="2,0" VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Border>

        <!-- Day Tasks Sidebar -->
        <Border Grid.Column="1" Style="{StaticResource CardStyle}" Padding="12">
            <DockPanel>
                <TextBlock x:Name="SelectedDateTitle" DockPanel.Dock="Top" FontSize="14" FontWeight="Bold"
                           Foreground="{DynamicResource TextBrush}" Margin="0,0,0,10"
                           Text="选择日期查看任务" />
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="DayTaskPanel" />
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
