<UserControl x:Class="ME.Views.TasksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:ME.Converters"
             IsVisibleChanged="TasksView_IsVisibleChanged">
    <UserControl.Resources>
        <converters:GoalTagColorConverter x:Key="TagColorConverter" />
        <converters:QuantitativeProgressConverter x:Key="QuantProgressConverter" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- Row 0: Calendar strip -->
            <RowDefinition Height="Auto" />   <!-- Row 1: Today goals + Timer + Stats -->
            <RowDefinition Height="Auto" />   <!-- Row 2: Add task + tag filter -->
            <RowDefinition Height="*" />      <!-- Row 3: Task list -->
        </Grid.RowDefinitions>

        <!-- Horizontal Calendar Strip: scroll wheel + today button -->
        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,12" Padding="12,8"
                SizeChanged="DateStrip_SizeChanged"
                PreviewMouseWheel="DateStrip_MouseWheel">
            <DockPanel>
                <!-- Left button = Today (跳转到今天) -->
                <Button DockPanel.Dock="Left" Content="今天" Click="TodayBtn_Click"
                        Style="{StaticResource SecondaryButtonStyle}" Padding="10,4" Margin="0,0,8,0" FontSize="12" />
                <TextBlock x:Name="MonthLabel" DockPanel.Dock="Left" FontSize="16" FontWeight="Bold"
                           Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"
                           Margin="0,0,16,0" MinWidth="60" />
                <ScrollViewer x:Name="DateScroller" HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Disabled" ClipToBounds="True">
                    <StackPanel x:Name="DateStrip" Orientation="Horizontal" />
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Row 1: Today Goals (left) + Timer+Stats (right, horizontal layout) -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <!-- Today Goals (left, compact) -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" x:Name="TodayGoalsSection" Visibility="Collapsed"
                    Padding="12,8,12,8">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="今日目标" FontSize="13" FontWeight="Bold"
                               Foreground="{DynamicResource TextBrush}" Margin="0,0,0,6" />
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="160">
                        <StackPanel x:Name="TodayGoalsPanel" />
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Timer + Stats (right, horizontal compact layout) -->
            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="12,8,12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Timer ring (compact) -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <Grid Width="90" Height="90" Margin="0,0,0,4">
                            <Ellipse Width="70" Height="70" Stroke="{DynamicResource BackgroundBrush}" StrokeThickness="5" />
                            <Ellipse x:Name="MiniTimerRing" Width="70" Height="70" Stroke="{DynamicResource PrimaryBrush}"
                                     StrokeThickness="5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                     RenderTransformOrigin="0.5,0.5" Opacity="0.3">
                                <Ellipse.StrokeDashArray>
                                    <DoubleCollection>102.1 102.1</DoubleCollection>
                                </Ellipse.StrokeDashArray>
                                <Ellipse.RenderTransform>
                                    <RotateTransform Angle="-90" />
                                </Ellipse.RenderTransform>
                            </Ellipse>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock x:Name="MiniTimerText" Text="00:00:00" FontSize="18" FontWeight="Bold"
                                           Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center" />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,1,0,0">
                                    <Border x:Name="MiniRunningDot" Width="5" Height="5" CornerRadius="2.5"
                                            Background="Gray" VerticalAlignment="Center" Margin="0,0,3,0" />
                                    <TextBlock x:Name="MiniRunningTag" Text="" FontSize="9"
                                               Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                        <!-- Quick controls -->
                        <DockPanel>
                            <Button x:Name="MiniTimerToggleBtn" DockPanel.Dock="Right" Content="开始"
                                    Click="MiniTimerToggle_Click" FontSize="10" Padding="10,3"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                            <ComboBox x:Name="MiniTagComboBox" Style="{StaticResource MacComboBoxStyle}"
                                      DisplayMemberPath="Name" SelectedValuePath="Id"
                                      FontSize="10" Height="24" Margin="0,0,6,0"
                                      VerticalAlignment="Center" />
                        </DockPanel>
                    </StackPanel>

                    <!-- Stats section (right of ring) -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <!-- Header with timer status -->
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="⏱ 计时器" FontSize="12" FontWeight="Bold"
                                       Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" />
                            <TextBlock x:Name="MiniTimerStatus" Text="" FontSize="10" HorizontalAlignment="Right"
                                       Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center" />
                        </DockPanel>

                        <!-- Today total time -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="6" Padding="8,5" Margin="0,0,0,4">
                            <DockPanel>
                                <TextBlock Text="今日统计" FontSize="11"
                                           Foreground="{DynamicResource SecondaryTextBrush}" />
                                <TextBlock x:Name="MiniTotalTime" Text="" FontSize="11" FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryBrush}" HorizontalAlignment="Right" />
                            </DockPanel>
                        </Border>

                        <!-- Tag time breakdown -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="6" Padding="8,4" Margin="0,0,0,4">
                            <StackPanel x:Name="MiniStatsPanel" Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="暂无数据" FontSize="10" Foreground="{DynamicResource SecondaryTextBrush}" />
                            </StackPanel>
                        </Border>

                        <!-- Task completion summary -->
                        <Border x:Name="MiniTaskSummary" Visibility="Collapsed"
                                Background="{DynamicResource CardBrush}" CornerRadius="6" Padding="8,4">
                            <DockPanel>
                                <TextBlock Text="今日完成" FontSize="10" Foreground="{DynamicResource SecondaryTextBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock x:Name="MiniCompletedCount" Text="0/0" FontSize="11" FontWeight="Bold"
                                           Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Right"
                                           VerticalAlignment="Center" />
                            </DockPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Add Task + Tag Filter -->
        <DockPanel Grid.Row="2" Margin="0,0,0,8">
            <Button Content="+ 添加任务" Click="AddTask_Click"
                    Style="{StaticResource PrimaryButtonStyle}" Padding="16,8" FontSize="13"
                    DockPanel.Dock="Left" />
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                          DockPanel.Dock="Right" Margin="8,0,0,0">
                <StackPanel x:Name="TagFilterPanel" Orientation="Horizontal" />
            </ScrollViewer>
        </DockPanel>

        <!-- Task List -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="TasksPanel" />
        </ScrollViewer>
    </Grid>
</UserControl>
