<Window x:Class="ME.Views.GoalEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ME.Views"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False"
        Title="添加目标" Height="700" Width="480"
        FocusManager.IsFocusScope="True">
    <Border CornerRadius="14" Background="{DynamicResource BackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Opacity="0.25" BlurRadius="24" ShadowDepth="2" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" CornerRadius="14,14,0,0" MouseLeftButtonDown="TitleBar_MouseDown"
                    Background="{DynamicResource CardBrush}">
                <Grid Margin="16,0">
                    <TextBlock x:Name="DialogTitle" Text="添加目标" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}"
                               VerticalAlignment="Center" HorizontalAlignment="Left" />
                    <Button Content="✕" Click="Cancel_Click"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="8,2" FontSize="12"
                            HorizontalAlignment="Right" VerticalAlignment="Center" />
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="20,12,20,0">
                <StackPanel>
                    <!-- Goal Name -->
                    <TextBlock Text="目标名称" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                    <TextBox x:Name="GoalNameBox" Style="{DynamicResource InputTextBoxStyle}"
                             Height="42" FontSize="14" AcceptsReturn="True" TextWrapping="Wrap" Margin="0,0,0,14"
                             VerticalContentAlignment="Center" />

                    <!-- Description -->
                    <TextBlock Text="目标描述" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                    <TextBox x:Name="GoalDescBox" Style="{DynamicResource InputTextBoxStyle}"
                             Height="50" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,14"
                             VerticalContentAlignment="Top" />

                    <!-- Tag Selection -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="标签" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"
                                   VerticalAlignment="Center" />
                        <Button x:Name="AddTagBtn" Content="+" Click="AddTag_Click"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="10,2" Margin="8,0,0,0" FontSize="14" FontWeight="Bold"
                                ToolTip="创建新标签" />
                    </StackPanel>
                    <WrapPanel x:Name="TagPanel" Margin="0,0,0,14" />

                    <!-- Date Range -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="开始日期" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                            <local:CustomDatePicker x:Name="StartDatePicker" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="结束日期" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                            <local:CustomDatePicker x:Name="EndDatePicker" />
                        </StackPanel>
                    </Grid>

                    <!-- Time Frame -->
                    <TextBlock Text="时间范围" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                    <ComboBox x:Name="TimeFrameCombo" Height="36" FontSize="13"
                              Style="{StaticResource MacComboBoxStyle}" Margin="0,0,0,14">
                        <ComboBoxItem Content="短期 (1年内)" IsSelected="True" />
                        <ComboBoxItem Content="长期 (1年以上)" />
                        <ComboBoxItem Content="灵感 (临时)" />
                    </ComboBox>

                    <!-- Quantitative Toggle -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <CheckBox x:Name="UseQuantitativeCheck"
                                  Checked="UseQuantitativeCheck_Changed" Unchecked="UseQuantitativeCheck_Changed" />
                        <TextBlock Text="启用量化进度" Foreground="{DynamicResource TextBrush}" FontSize="13"
                                   VerticalAlignment="Center" Margin="8,0,0,0" />
                    </StackPanel>

                    <!-- Quantitative Options -->
                    <Border x:Name="QuantitativePanel" Style="{DynamicResource CardStyle}"
                            Visibility="Collapsed" Margin="0,0,0,14">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="起始值" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <TextBox x:Name="QuantStartBox" Style="{DynamicResource InputTextBoxStyle}" Height="36" FontSize="13"
                                             VerticalContentAlignment="Center" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="目标值" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <TextBox x:Name="QuantTargetBox" Style="{DynamicResource InputTextBoxStyle}" Height="36" FontSize="13"
                                             VerticalContentAlignment="Center" />
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="计算方式" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                            <ComboBox x:Name="QuantModeCombo" Height="36" FontSize="13"
                                      Style="{StaticResource MacComboBoxStyle}" Margin="0,0,0,10">
                                <ComboBoxItem Content="求和 (累加)" IsSelected="True" />
                                <ComboBoxItem Content="更新 (覆盖)" />
                            </ComboBox>
                            <TextBlock Text="单位 (如: 页/公里/元)" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                            <TextBox x:Name="QuantUnitBox" Style="{DynamicResource InputTextBoxStyle}"
                                     Width="180" HorizontalAlignment="Left" Height="36" FontSize="13"
                                     VerticalContentAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <!-- Subtask Section -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="子任务" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"
                                   VerticalAlignment="Center" />
                        <Button x:Name="AddSubtaskBtn" Content="+" Click="AddSubtask_Click"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="10,2" Margin="8,0,0,0" FontSize="14" FontWeight="Bold"
                                ToolTip="添加子任务" />
                    </StackPanel>
                    <ItemsControl x:Name="SubtaskList" Margin="0,0,0,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource BackgroundBrush}" CornerRadius="8"
                                        Padding="12,8" Margin="0,0,0,4">
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right" Content="-" Click="RemoveSubtask_Click"
                                                Style="{DynamicResource SecondaryButtonStyle}"
                                                Padding="10,2" FontSize="14" FontWeight="Bold" Margin="8,0,0,0"
                                                ToolTip="删除子任务" />
                                        <Button DockPanel.Dock="Right" Content="编辑" Click="EditSubtask_Click"
                                                Style="{DynamicResource SecondaryButtonStyle}"
                                                Padding="10,2" FontSize="11"
                                                ToolTip="编辑子任务" />
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextBrush}" />
                                            <TextBlock Text="{Binding Description}" FontSize="11"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,12,20,16">
                <Button Content="取消" Style="{DynamicResource SecondaryButtonStyle}"
                        Click="Cancel_Click" Padding="24,8" Margin="0,0,10,0" FontSize="13" />
                <Button Content="保存" Style="{DynamicResource PrimaryButtonStyle}"
                        Click="Save_Click" Padding="24,8" FontSize="13" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
