<Window x:Class="ME.Views.GoalEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="添加目标" Height="800" Width="500"
        WindowStartupLocation="CenterOwner"
        MinHeight="500" MinWidth="400"
        Background="{StaticResource BackgroundBrush}"
        ResizeMode="CanResizeWithGrip"
        FocusManager.IsFocusScope="True">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel>
            <!-- Goal Name -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="目标名称" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,6" />
                <TextBox x:Name="GoalNameBox" Style="{StaticResource InputTextBoxStyle}" 
                         Height="60" FontSize="14" AcceptsReturn="True" TextWrapping="Wrap" />
            </StackPanel>

            <!-- Description -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="目标描述" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,6" />
                <TextBox x:Name="GoalDescBox" Style="{StaticResource InputTextBoxStyle}" 
                         Height="60" TextWrapping="Wrap" AcceptsReturn="True" TextAlignment="Left" />
            </StackPanel>

            <!-- Tag Selection -->
            <StackPanel Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="标签" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" 
                               VerticalAlignment="Center" />
                    <Button x:Name="AddTagBtn" Content="+" Click="AddTag_Click"
                            Style="{StaticResource SecondaryButtonStyle}" 
                            Padding="10,4" Margin="8,0,0,0" FontSize="14" FontWeight="Bold"
                            ToolTip="创建新标签" />
                </StackPanel>
                <WrapPanel x:Name="TagPanel" />
            </StackPanel>

            <!-- Date Range -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="开始日期" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,6" />
                    <DatePicker x:Name="StartDatePicker" Height="36" FontSize="13" 
                                Style="{StaticResource MacDatePickerStyle}" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="结束日期" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,6" />
                    <DatePicker x:Name="EndDatePicker" Height="36" FontSize="13" 
                                Style="{StaticResource MacDatePickerStyle}" />
                </StackPanel>
            </Grid>

            <!-- Time Frame -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="时间范围" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,6" />
                <ComboBox x:Name="TimeFrameCombo" Height="36" FontSize="13"
                          Style="{StaticResource MacComboBoxStyle}">
                    <ComboBoxItem Content="短期 (1年内)" IsSelected="True" />
                    <ComboBoxItem Content="长期 (1年以上)" />
                    <ComboBoxItem Content="灵感 (临时)" />
                </ComboBox>
            </StackPanel>

            <!-- Quantitative Toggle -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <CheckBox x:Name="UseQuantitativeCheck" 
                          Checked="UseQuantitativeCheck_Changed" Unchecked="UseQuantitativeCheck_Changed" />
                <TextBlock Text="启用量化进度" Foreground="{StaticResource TextBrush}" FontSize="13" 
                           VerticalAlignment="Center" Margin="8,0,0,0" />
            </StackPanel>

            <!-- Quantitative Options -->
            <Border x:Name="QuantitativePanel" Style="{StaticResource CardStyle}" 
                    Visibility="Collapsed" Margin="0,0,0,16">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="起始值" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,6" />
                            <TextBox x:Name="QuantStartBox" Style="{StaticResource InputTextBoxStyle}" 
                                     Height="48" FontSize="14" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="目标值" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,6" />
                            <TextBox x:Name="QuantTargetBox" Style="{StaticResource InputTextBoxStyle}" 
                                     Height="48" FontSize="14" />
                        </StackPanel>
                    </Grid>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="计算方式" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,6" />
                        <ComboBox x:Name="QuantModeCombo" Height="36" FontSize="13"
                                  Style="{StaticResource MacComboBoxStyle}">
                            <ComboBoxItem Content="求和 (累加)" IsSelected="True" />
                            <ComboBoxItem Content="更新 (覆盖)" />
                        </ComboBox>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="单位 (如: 页/公里/元)" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,6" />
                        <TextBox x:Name="QuantUnitBox" Style="{StaticResource InputTextBoxStyle}" 
                                 Width="200" HorizontalAlignment="Left" Height="48" FontSize="14" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Subtask Section -->
            <StackPanel Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="子任务" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" 
                               VerticalAlignment="Center" />
                    <Button x:Name="AddSubtaskBtn" Content="+" Click="AddSubtask_Click"
                            Style="{StaticResource SecondaryButtonStyle}" 
                            Padding="10,4" Margin="8,0,0,0" FontSize="16" FontWeight="Bold"
                            ToolTip="添加子任务" />
                </StackPanel>
                <ItemsControl x:Name="SubtaskList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource BackgroundBrush}" CornerRadius="8" 
                                    Padding="12,10" Margin="0,0,0,6">
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" Content="-" Click="RemoveSubtask_Click"
                                            Style="{StaticResource SecondaryButtonStyle}" 
                                            Padding="10,4" FontSize="14" FontWeight="Bold" Margin="8,0,0,0"
                                            ToolTip="删除子任务" />
                                    <Button DockPanel.Dock="Right" Content="编辑" Click="EditSubtask_Click"
                                            Style="{StaticResource SecondaryButtonStyle}" 
                                            Padding="10,4" FontSize="11" Margin="0,0,4,0"
                                            ToolTip="编辑子任务" />
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextBrush}" />
                                        <TextBlock Text="{Binding Description}" FontSize="11"
                                                   Foreground="{StaticResource SecondaryTextBrush}" 
                                                   TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,24,0,0">
                <Button Content="取消" Style="{StaticResource SecondaryButtonStyle}" 
                        Click="Cancel_Click" Padding="28,10" Margin="0,0,12,0" />
                <Button Content="保存" Style="{StaticResource PrimaryButtonStyle}" 
                        Click="Save_Click" Padding="28,10" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
