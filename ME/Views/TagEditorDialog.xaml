<Window x:Class="ME.Views.TagEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False"
        Title="编辑标签" Height="380" Width="340">
    <Border CornerRadius="14" Background="{DynamicResource BackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Opacity="0.25" BlurRadius="24" ShadowDepth="2" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" CornerRadius="14,14,0,0" MouseLeftButtonDown="TitleBar_MouseDown"
                    Background="{DynamicResource CardBrush}">
                <Grid Margin="16,0">
                    <TextBlock Text="编辑标签" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}"
                               VerticalAlignment="Center" HorizontalAlignment="Left" />
                    <Button Content="✕" Click="Cancel_Click"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="8,2" FontSize="12"
                            HorizontalAlignment="Right" VerticalAlignment="Center" />
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="20,12,20,0">
                <StackPanel>
                    <TextBlock Text="标签名称" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                    <TextBox x:Name="NameBox" Style="{DynamicResource InputTextBoxStyle}"
                             Height="38" FontSize="14" Margin="0,0,0,14" />

                    <TextBlock Text="颜色" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8" />
                    <ItemsControl x:Name="ColorPalette" Margin="0,0,0,14">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>

                    <TextBlock Text="自定义颜色 (Hex)" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                    <TextBox x:Name="ColorBox" Style="{DynamicResource InputTextBoxStyle}"
                             Height="38" FontSize="14" TextChanged="ColorBox_TextChanged" Margin="0,0,0,14" />

                    <TextBlock Text="备注" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                    <TextBox x:Name="NotesBox" Style="{DynamicResource InputTextBoxStyle}"
                             Height="60" FontSize="13" AcceptsReturn="True" TextWrapping="Wrap" />
                </StackPanel>
            </ScrollViewer>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,12,20,16">
                <Button Content="取消" Click="Cancel_Click"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="20,8" Margin="0,0,10,0" FontSize="13" />
                <Button Content="保存" Click="Save_Click"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        Padding="20,8" FontSize="13" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
