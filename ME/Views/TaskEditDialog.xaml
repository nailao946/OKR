<Window x:Class="ME.Views.TaskEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ME.Views"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False"
        Title="添加任务" Width="460" MaxHeight="680"
        SizeToContent="Height"
        FocusManager.IsFocusScope="True">
    <Border CornerRadius="14" Background="{DynamicResource BackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Opacity="0.25" BlurRadius="24" ShadowDepth="2" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" CornerRadius="14,14,0,0" MouseLeftButtonDown="TitleBar_MouseDown"
                    Background="{DynamicResource CardBrush}">
                <Grid Margin="16,0">
                    <TextBlock x:Name="DialogTitle" Text="添加任务" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}"
                               VerticalAlignment="Center" HorizontalAlignment="Left" />
                    <Button Content="✕" Click="Cancel_Click"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="8,2" FontSize="12"
                            HorizontalAlignment="Right" VerticalAlignment="Center" />
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer x:Name="ContentScroller" Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="20,12,20,0"
                          MaxHeight="580">
                <StackPanel>
                    <!-- Task Name -->
                    <TextBlock Text="任务名称" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                    <TextBox x:Name="TaskNameBox" Style="{DynamicResource InputTextBoxStyle}"
                             Height="42" FontSize="14" AcceptsReturn="False" Margin="0,0,0,12"
                             VerticalContentAlignment="Center" />

                    <!-- Description -->
                    <TextBlock Text="任务描述" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                    <TextBox x:Name="TaskDescBox" Style="{DynamicResource InputTextBoxStyle}"
                             Height="42" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,12"
                             VerticalContentAlignment="Top" />

                    <!-- Date Range -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="开始日期" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                            <local:CustomDatePicker x:Name="StartDatePicker" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="结束日期" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                            <local:CustomDatePicker x:Name="EndDatePicker" />
                        </StackPanel>
                    </Grid>

                    <!-- Task Type -->
                    <TextBlock Text="任务类型" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                    <ComboBox x:Name="TaskTypeCombo" Height="36" FontSize="13"
                              Style="{StaticResource MacComboBoxStyle}"
                              SelectionChanged="TaskTypeCombo_SelectionChanged" Margin="0,0,0,12">
                        <ComboBoxItem Content="单次任务" IsSelected="True" />
                        <ComboBoxItem Content="循环任务" />
                    </ComboBox>

                    <!-- Repeat Options -->
                    <StackPanel x:Name="RepeatOptionsPanel" Margin="0,0,0,12" Visibility="Collapsed">
                        <TextBlock Text="循环方式" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                        <ComboBox x:Name="RepeatModeCombo" Height="36" FontSize="13"
                                  Style="{StaticResource MacComboBoxStyle}"
                                  SelectionChanged="RepeatModeCombo_SelectionChanged" Margin="0,0,0,10">
                            <ComboBoxItem Content="无循环" IsSelected="True" />
                            <ComboBoxItem Content="每天" />
                            <ComboBoxItem Content="每周工作日(1-5)" />
                            <ComboBoxItem Content="每周六周日" />
                            <ComboBoxItem Content="每周" />
                            <ComboBoxItem Content="每月" />
                            <ComboBoxItem Content="定期循环" />
                            <ComboBoxItem Content="自定义频次" />
                        </ComboBox>

                        <!-- Weekly Days Selection -->
                        <Border x:Name="WeeklyDaysPanel" Margin="0,0,0,8" Visibility="Collapsed"
                                Style="{DynamicResource CardStyle}" Padding="10">
                            <StackPanel>
                                <TextBlock Text="选择星期（可多选）" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                <ListBox x:Name="WeekDayListBox" SelectionMode="Multiple" Height="160"
                                         Style="{StaticResource MacListBoxStyle}">
                                    <ListBoxItem Content="周一" Tag="0" />
                                    <ListBoxItem Content="周二" Tag="1" />
                                    <ListBoxItem Content="周三" Tag="2" />
                                    <ListBoxItem Content="周四" Tag="3" />
                                    <ListBoxItem Content="周五" Tag="4" />
                                    <ListBoxItem Content="周六" Tag="5" />
                                    <ListBoxItem Content="周日" Tag="6" />
                                </ListBox>
                            </StackPanel>
                        </Border>

                        <!-- Monthly Day Selection -->
                        <Border x:Name="MonthlyDayPanel" Margin="0,0,0,8" Visibility="Collapsed"
                                Style="{DynamicResource CardStyle}" Padding="10">
                            <StackPanel>
                                <TextBlock Text="选择日期（单选）" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                <ListBox x:Name="MonthDayListBox" SelectionMode="Single" Height="180"
                                         Style="{StaticResource MacListBoxStyle}">
                                    <ListBoxItem Content="1日" Tag="1" /><ListBoxItem Content="2日" Tag="2" />
                                    <ListBoxItem Content="3日" Tag="3" /><ListBoxItem Content="4日" Tag="4" />
                                    <ListBoxItem Content="5日" Tag="5" /><ListBoxItem Content="6日" Tag="6" />
                                    <ListBoxItem Content="7日" Tag="7" /><ListBoxItem Content="8日" Tag="8" />
                                    <ListBoxItem Content="9日" Tag="9" /><ListBoxItem Content="10日" Tag="10" />
                                    <ListBoxItem Content="11日" Tag="11" /><ListBoxItem Content="12日" Tag="12" />
                                    <ListBoxItem Content="13日" Tag="13" /><ListBoxItem Content="14日" Tag="14" />
                                    <ListBoxItem Content="15日" Tag="15" /><ListBoxItem Content="16日" Tag="16" />
                                    <ListBoxItem Content="17日" Tag="17" /><ListBoxItem Content="18日" Tag="18" />
                                    <ListBoxItem Content="19日" Tag="19" /><ListBoxItem Content="20日" Tag="20" />
                                    <ListBoxItem Content="21日" Tag="21" /><ListBoxItem Content="22日" Tag="22" />
                                    <ListBoxItem Content="23日" Tag="23" /><ListBoxItem Content="24日" Tag="24" />
                                    <ListBoxItem Content="25日" Tag="25" /><ListBoxItem Content="26日" Tag="26" />
                                    <ListBoxItem Content="27日" Tag="27" /><ListBoxItem Content="28日" Tag="28" />
                                    <ListBoxItem Content="29日" Tag="29" /><ListBoxItem Content="30日" Tag="30" />
                                    <ListBoxItem Content="31日" Tag="31" /><ListBoxItem Content="最后一天" Tag="32" />
                                </ListBox>
                            </StackPanel>
                        </Border>

                        <!-- Interval for fixed repeat -->
                        <Border x:Name="IntervalPanel" Margin="0,0,0,8" Visibility="Collapsed"
                                Style="{DynamicResource CardStyle}" Padding="10">
                            <StackPanel>
                                <TextBlock Text="每N天循环" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                <StackPanel Orientation="Horizontal">
                                    <TextBox x:Name="IntervalDaysBox" Style="{DynamicResource InputTextBoxStyle}"
                                             Width="80" Height="36" FontSize="13" VerticalContentAlignment="Center" />
                                    <TextBlock Text="天" FontSize="14" Foreground="{DynamicResource TextBrush}"
                                               VerticalAlignment="Center" Margin="8,0,0,0" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Custom frequency -->
                        <Border x:Name="CustomFreqPanel" Margin="0,0,0,0" Visibility="Collapsed"
                                Style="{DynamicResource CardStyle}" Padding="10">
                            <StackPanel>
                                <TextBlock Text="自定义频次" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8" />
                                <StackPanel Margin="0,0,0,8">
                                    <TextBlock Text="每天完成次数" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,4" />
                                    <StackPanel Orientation="Horizontal">
                                        <TextBox x:Name="CustomTimesPerDayBox" Style="{DynamicResource InputTextBoxStyle}"
                                                 Width="80" Height="36" FontSize="13" VerticalContentAlignment="Center" />
                                        <TextBlock Text="次/天" FontSize="14" Foreground="{DynamicResource TextBrush}"
                                                   VerticalAlignment="Center" Margin="8,0,0,0" />
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="每周完成天数" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,4" />
                                    <StackPanel Orientation="Horizontal">
                                        <TextBox x:Name="CustomDaysPerWeekBox" Style="{DynamicResource InputTextBoxStyle}"
                                                 Width="80" Height="36" FontSize="13" VerticalContentAlignment="Center" />
                                        <TextBlock Text="天/周" FontSize="14" Foreground="{DynamicResource TextBrush}"
                                                   VerticalAlignment="Center" Margin="8,0,0,0" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Quantitative Toggle -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <CheckBox x:Name="UseQuantitativeCheck"
                                  Checked="UseQuantitativeCheck_Changed" Unchecked="UseQuantitativeCheck_Changed" />
                        <TextBlock Text="启用量化进度" Foreground="{DynamicResource TextBrush}" FontSize="13"
                                   VerticalAlignment="Center" Margin="8,0,0,0" />
                    </StackPanel>

                    <!-- Quantitative Options -->
                    <Border x:Name="QuantitativePanel" Style="{DynamicResource CardStyle}"
                            Visibility="Collapsed" Margin="0,0,0,12">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="起始值" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <TextBox x:Name="QuantStartBox" Style="{DynamicResource InputTextBoxStyle}" Height="36" FontSize="13"
                                             VerticalContentAlignment="Center" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="目标值" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <TextBox x:Name="QuantTargetBox" Style="{DynamicResource InputTextBoxStyle}" Height="36" FontSize="13"
                                             VerticalContentAlignment="Center" />
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="计算方式" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                            <ComboBox x:Name="QuantModeCombo" Height="36" FontSize="13"
                                      Style="{StaticResource MacComboBoxStyle}" Margin="0,0,0,10">
                                <ComboBoxItem Content="求和 (累加)" IsSelected="True" />
                                <ComboBoxItem Content="更新 (覆盖)" />
                            </ComboBox>
                            <TextBlock Text="单位 (如: 页/公里/元)" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                            <TextBox x:Name="QuantUnitBox" Style="{DynamicResource InputTextBoxStyle}"
                                     Width="180" HorizontalAlignment="Left" Height="36" FontSize="13"
                                     VerticalContentAlignment="Center" />
                            <TextBlock Text="每日目标 (达到此值算当日完成)" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,10,0,6" />
                            <TextBox x:Name="QuantDailyMinBox" Style="{DynamicResource InputTextBoxStyle}"
                                     Width="180" HorizontalAlignment="Left" Height="36" FontSize="13"
                                     VerticalContentAlignment="Center" />
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0" x:Name="CountTowardsParentPanel" Visibility="Collapsed">
                                <CheckBox x:Name="CountTowardsParentCheck" />
                                <TextBlock Text="计算入主任务进度" Foreground="{DynamicResource TextBrush}" FontSize="13"
                                           VerticalAlignment="Center" Margin="8,0,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Subtask Section -->
                    <StackPanel x:Name="SubtaskSection" Margin="0,0,0,8" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="子任务" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"
                                       VerticalAlignment="Center" />
                            <Button Content="+" Click="AddSubtask_Click"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Padding="10,2" Margin="8,0,0,0" FontSize="14" FontWeight="Bold"
                                    ToolTip="添加子任务" />
                        </StackPanel>
                        <ItemsControl x:Name="SubtaskList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource BackgroundBrush}" CornerRadius="6"
                                            Padding="10,6" Margin="0,0,0,4">
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right" Content="-" Click="RemoveSubtask_Click"
                                                    Style="{DynamicResource SecondaryButtonStyle}"
                                                    Padding="8,2" FontSize="14" FontWeight="Bold" Margin="6,0,0,0" />
                                            <Button DockPanel.Dock="Right" Content="编辑" Click="EditSubtask_Click"
                                                    Style="{DynamicResource SecondaryButtonStyle}"
                                                    Padding="8,2" FontSize="11" />
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextBrush}" />
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,12,20,16">
                <Button Content="取消" Style="{DynamicResource SecondaryButtonStyle}"
                        Click="Cancel_Click" Padding="24,8" Margin="0,0,10,0" FontSize="13" />
                <Button Content="保存" Style="{DynamicResource PrimaryButtonStyle}"
                        Click="Save_Click" Padding="24,8" FontSize="13" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
