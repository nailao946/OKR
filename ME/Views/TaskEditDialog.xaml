<Window x:Class="ME.Views.TaskEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="添加任务" Height="680" Width="480"
        WindowStartupLocation="CenterOwner"
        MinHeight="500" MinWidth="400"
        Background="{StaticResource BackgroundBrush}"
        ResizeMode="CanResizeWithGrip"
        FocusManager.IsFocusScope="True">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel>
            <!-- Task Name -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="任务名称" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,6" />
                <TextBox x:Name="TaskNameBox" Style="{StaticResource InputTextBoxStyle}" 
                         Height="50" FontSize="14" AcceptsReturn="False" />
            </StackPanel>

            <!-- Description -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="任务描述" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,6" />
                <TextBox x:Name="TaskDescBox" Style="{StaticResource InputTextBoxStyle}" 
                         Height="50" TextWrapping="Wrap" AcceptsReturn="True" TextAlignment="Left" />
            </StackPanel>

            <!-- Date Range -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="开始日期" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,6" />
                    <DatePicker x:Name="StartDatePicker" Height="36" FontSize="13" 
                                Style="{StaticResource MacDatePickerStyle}" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="结束日期" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,6" />
                    <DatePicker x:Name="EndDatePicker" Height="36" FontSize="13" 
                                Style="{StaticResource MacDatePickerStyle}" />
                </StackPanel>
            </Grid>

            <!-- Task Type -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="任务类型" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,6" />
                <ComboBox x:Name="TaskTypeCombo" Height="36" FontSize="13"
                          Style="{StaticResource MacComboBoxStyle}"
                          SelectionChanged="TaskTypeCombo_SelectionChanged">
                    <ComboBoxItem Content="单次任务" IsSelected="True" />
                    <ComboBoxItem Content="循环任务" />
                </ComboBox>
            </StackPanel>

            <!-- Repeat Options -->
            <StackPanel x:Name="RepeatOptionsPanel" Margin="0,0,0,16" Visibility="Collapsed">
                <TextBlock Text="循环方式" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,6" />
                <ComboBox x:Name="RepeatModeCombo" Height="40" FontSize="13"
                          Style="{StaticResource MacComboBoxStyle}"
                          SelectionChanged="RepeatModeCombo_SelectionChanged">
                    <ComboBoxItem Content="无循环" IsSelected="True" />
                    <ComboBoxItem Content="每天" />
                    <ComboBoxItem Content="每周工作日(1-5)" />
                    <ComboBoxItem Content="每周六周日" />
                    <ComboBoxItem Content="每周" />
                    <ComboBoxItem Content="每月" />
                    <ComboBoxItem Content="定期循环" />
                    <ComboBoxItem Content="自定义频次" />
                </ComboBox>

                <!-- Weekly Days Selection -->
                <Border x:Name="WeeklyDaysPanel" Margin="0,12,0,0" Visibility="Collapsed" 
                        Style="{StaticResource CardStyle}" Padding="12">
                    <StackPanel>
                        <TextBlock Text="选择星期（可多选）" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,8" />
                        <ListBox x:Name="WeekDayListBox" SelectionMode="Multiple" Height="180"
                                 Style="{StaticResource MacListBoxStyle}">
                            <ListBoxItem Content="周一" Tag="0" />
                            <ListBoxItem Content="周二" Tag="1" />
                            <ListBoxItem Content="周三" Tag="2" />
                            <ListBoxItem Content="周四" Tag="3" />
                            <ListBoxItem Content="周五" Tag="4" />
                            <ListBoxItem Content="周六" Tag="5" />
                            <ListBoxItem Content="周日" Tag="6" />
                        </ListBox>
                    </StackPanel>
                </Border>

                <!-- Monthly Day Selection -->
                <Border x:Name="MonthlyDayPanel" Margin="0,12,0,0" Visibility="Collapsed"
                        Style="{StaticResource CardStyle}" Padding="12">
                    <StackPanel>
                        <TextBlock Text="选择日期（单选）" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,8" />
                        <ListBox x:Name="MonthDayListBox" SelectionMode="Single" Height="200"
                                 Style="{StaticResource MacListBoxStyle}">
                            <ListBoxItem Content="1日" Tag="1" />
                            <ListBoxItem Content="2日" Tag="2" />
                            <ListBoxItem Content="3日" Tag="3" />
                            <ListBoxItem Content="4日" Tag="4" />
                            <ListBoxItem Content="5日" Tag="5" />
                            <ListBoxItem Content="6日" Tag="6" />
                            <ListBoxItem Content="7日" Tag="7" />
                            <ListBoxItem Content="8日" Tag="8" />
                            <ListBoxItem Content="9日" Tag="9" />
                            <ListBoxItem Content="10日" Tag="10" />
                            <ListBoxItem Content="11日" Tag="11" />
                            <ListBoxItem Content="12日" Tag="12" />
                            <ListBoxItem Content="13日" Tag="13" />
                            <ListBoxItem Content="14日" Tag="14" />
                            <ListBoxItem Content="15日" Tag="15" />
                            <ListBoxItem Content="16日" Tag="16" />
                            <ListBoxItem Content="17日" Tag="17" />
                            <ListBoxItem Content="18日" Tag="18" />
                            <ListBoxItem Content="19日" Tag="19" />
                            <ListBoxItem Content="20日" Tag="20" />
                            <ListBoxItem Content="21日" Tag="21" />
                            <ListBoxItem Content="22日" Tag="22" />
                            <ListBoxItem Content="23日" Tag="23" />
                            <ListBoxItem Content="24日" Tag="24" />
                            <ListBoxItem Content="25日" Tag="25" />
                            <ListBoxItem Content="26日" Tag="26" />
                            <ListBoxItem Content="27日" Tag="27" />
                            <ListBoxItem Content="28日" Tag="28" />
                            <ListBoxItem Content="29日" Tag="29" />
                            <ListBoxItem Content="30日" Tag="30" />
                            <ListBoxItem Content="31日" Tag="31" />
                            <ListBoxItem Content="最后一天" Tag="32" />
                        </ListBox>
                    </StackPanel>
                </Border>

                <!-- Interval for fixed repeat -->
                <Border x:Name="IntervalPanel" Margin="0,12,0,0" Visibility="Collapsed"
                        Style="{StaticResource CardStyle}" Padding="12">
                    <StackPanel>
                        <TextBlock Text="每N天循环" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,6" />
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="IntervalDaysBox" Style="{StaticResource InputTextBoxStyle}" 
                                     Width="80" Height="42" FontSize="14" Foreground="{StaticResource TextBrush}" Background="{StaticResource CardBrush}" />
                            <TextBlock Text="天" FontSize="14" Foreground="{StaticResource TextBrush}" 
                                       VerticalAlignment="Center" Margin="8,0,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Custom frequency -->
                <Border x:Name="CustomFreqPanel" Margin="0,12,0,0" Visibility="Collapsed"
                        Style="{StaticResource CardStyle}" Padding="12">
                    <StackPanel>
                        <TextBlock Text="自定义频次" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,8" />
                        <StackPanel Margin="0,0,0,8">
                            <TextBlock Text="每天完成次数" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,4" />
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="CustomTimesPerDayBox" Style="{StaticResource InputTextBoxStyle}" 
                                         Width="80" Height="42" FontSize="14" Foreground="{StaticResource TextBrush}" Background="{StaticResource CardBrush}" />
                                <TextBlock Text="次/天" FontSize="14" Foreground="{StaticResource TextBrush}" 
                                           VerticalAlignment="Center" Margin="8,0,0,0" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="每周完成天数" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,4" />
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="CustomDaysPerWeekBox" Style="{StaticResource InputTextBoxStyle}" 
                                         Width="80" Height="42" FontSize="14" Foreground="{StaticResource TextBrush}" Background="{StaticResource CardBrush}" />
                                <TextBlock Text="天/周" FontSize="14" Foreground="{StaticResource TextBrush}" 
                                           VerticalAlignment="Center" Margin="8,0,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Quantitative Toggle -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <CheckBox x:Name="UseQuantitativeCheck" 
                          Checked="UseQuantitativeCheck_Changed" Unchecked="UseQuantitativeCheck_Changed" />
                <TextBlock Text="启用量化进度" Foreground="{StaticResource TextBrush}" FontSize="13" 
                           VerticalAlignment="Center" Margin="8,0,0,0" />
            </StackPanel>

            <!-- Quantitative Options -->
            <Border x:Name="QuantitativePanel" Style="{StaticResource CardStyle}" 
                    Visibility="Collapsed" Margin="0,0,0,16">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="起始值" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,6" />
                            <TextBox x:Name="QuantStartBox" Style="{StaticResource InputTextBoxStyle}" 
                                     Height="48" FontSize="14" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="目标值" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,6" />
                            <TextBox x:Name="QuantTargetBox" Style="{StaticResource InputTextBoxStyle}" 
                                     Height="48" FontSize="14" />
                        </StackPanel>
                    </Grid>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="计算方式" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,6" />
                        <ComboBox x:Name="QuantModeCombo" Height="36" FontSize="13"
                                  Style="{StaticResource MacComboBoxStyle}">
                            <ComboBoxItem Content="求和 (累加)" IsSelected="True" />
                            <ComboBoxItem Content="更新 (覆盖)" />
                        </ComboBox>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="单位 (如: 页/公里/元)" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,6" />
                        <TextBox x:Name="QuantUnitBox" Style="{StaticResource InputTextBoxStyle}" 
                                 Width="200" HorizontalAlignment="Left" Height="48" FontSize="14" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0" x:Name="CountTowardsParentPanel" Visibility="Collapsed">
                        <CheckBox x:Name="CountTowardsParentCheck" />
                        <TextBlock Text="计算入主任务进度" Foreground="{StaticResource TextBrush}" FontSize="13" 
                                   VerticalAlignment="Center" Margin="8,0,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Subtask Section -->
            <StackPanel x:Name="SubtaskSection" Margin="0,0,0,16" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="子任务" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" 
                               VerticalAlignment="Center" />
                    <Button Content="+" Click="AddSubtask_Click"
                            Style="{StaticResource SecondaryButtonStyle}" 
                            Padding="10,4" Margin="8,0,0,0" FontSize="16" FontWeight="Bold"
                            ToolTip="添加子任务" />
                </StackPanel>
                <ItemsControl x:Name="SubtaskList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource BackgroundBrush}" CornerRadius="6" 
                                    Padding="10,8" Margin="0,0,0,4">
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" Content="-" Click="RemoveSubtask_Click"
                                            Style="{StaticResource SecondaryButtonStyle}" 
                                            Padding="8,4" FontSize="14" FontWeight="Bold" Margin="6,0,0,0" />
                                    <Button DockPanel.Dock="Right" Content="编辑" Click="EditSubtask_Click"
                                            Style="{StaticResource SecondaryButtonStyle}" 
                                            Padding="8,4" FontSize="11" />
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextBrush}" />
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,24,0,0">
                <Button Content="取消" Style="{StaticResource SecondaryButtonStyle}" 
                        Click="Cancel_Click" Padding="28,10" Margin="0,0,12,0" />
                <Button Content="保存" Style="{StaticResource PrimaryButtonStyle}" 
                        Click="Save_Click" Padding="28,10" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
