<Window x:Class="ME.Views.QuantitativeInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False"
        Title="量化数据录入" Height="400" Width="380"
        KeyDown="Window_KeyDown">
    <Border CornerRadius="14" Background="{DynamicResource BackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Opacity="0.25" BlurRadius="24" ShadowDepth="2" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" CornerRadius="14,14,0,0" MouseLeftButtonDown="TitleBar_MouseDown"
                    Background="{DynamicResource CardBrush}">
                <Grid Margin="16,0">
                    <TextBlock Text="量化数据录入" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}"
                               VerticalAlignment="Center" HorizontalAlignment="Left" />
                    <Button Content="✕" Click="Cancel_Click"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="8,2" FontSize="12"
                            HorizontalAlignment="Right" VerticalAlignment="Center" />
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="20,12,20,0">
                <StackPanel>
                    <TextBlock x:Name="TaskTitleText" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4" />
                    <TextBlock x:Name="ModeText" FontSize="12"
                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,16" />

                    <Border Style="{DynamicResource CardStyle}" Padding="14" Margin="0,0,0,16">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="当前值" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" />
                                    <TextBlock x:Name="CurrentValueText" FontSize="22" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryBrush}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="目标值" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" />
                                    <TextBlock x:Name="TargetValueText" FontSize="22" FontWeight="Bold"
                                               Foreground="{DynamicResource TextBrush}" />
                                </StackPanel>
                            </Grid>
                            <ProgressBar x:Name="ProgressBar" Maximum="100" Height="6"
                                         Background="{DynamicResource BackgroundBrush}"
                                         Foreground="{DynamicResource PrimaryBrush}" />
                            <TextBlock x:Name="ProgressText" FontSize="11"
                                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,4,0,0" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <TextBlock x:Name="InputLabel" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                    <TextBox x:Name="ValueInput" Style="{DynamicResource InputTextBoxStyle}"
                             Height="44" FontSize="16" FontWeight="SemiBold" />
                </StackPanel>
            </ScrollViewer>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,12,20,16">
                <Button Content="取消" Style="{DynamicResource SecondaryButtonStyle}"
                        Click="Cancel_Click" Padding="24,8" Margin="0,0,10,0" FontSize="13" />
                <Button Content="确认" Style="{DynamicResource PrimaryButtonStyle}"
                        Click="Confirm_Click" Padding="24,8" FontSize="13" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
