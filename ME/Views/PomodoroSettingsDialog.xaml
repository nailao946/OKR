<Window x:Class="ME.Views.PomodoroSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False"
        Height="360" Width="340">
    <Border CornerRadius="14" Background="{DynamicResource BackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Opacity="0.25" BlurRadius="24" ShadowDepth="2" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" CornerRadius="14,14,0,0" MouseLeftButtonDown="TitleBar_MouseDown"
                    Background="{DynamicResource CardBrush}">
                <Grid Margin="16,0">
                    <TextBlock Text="番茄钟设置" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}"
                               VerticalAlignment="Center" HorizontalAlignment="Left" />
                    <Button Content="✕" Click="Close_Click"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="8,2" FontSize="12"
                            HorizontalAlignment="Right" VerticalAlignment="Center" />
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="24,16,24,0">
                <StackPanel>
                    <Border Style="{DynamicResource CardStyle}" Padding="14" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="工作时间 (分钟)" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                            <TextBox x:Name="WorkMinutesBox" Style="{DynamicResource InputTextBoxStyle}"
                                     Text="25" Height="36" FontSize="13" VerticalContentAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <Border Style="{DynamicResource CardStyle}" Padding="14" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="短休息 (分钟)" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                            <TextBox x:Name="ShortBreakBox" Style="{DynamicResource InputTextBoxStyle}"
                                     Text="5" Height="36" FontSize="13" VerticalContentAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <Border Style="{DynamicResource CardStyle}" Padding="14" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="长休息 (分钟)" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                            <TextBox x:Name="LongBreakBox" Style="{DynamicResource InputTextBoxStyle}"
                                     Text="15" Height="36" FontSize="13" VerticalContentAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <Border Style="{DynamicResource CardStyle}" Padding="14" Margin="0,0,0,0">
                        <StackPanel>
                            <TextBlock Text="长休息间隔 (番茄数)" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                            <TextBox x:Name="BeforeLongBox" Style="{DynamicResource InputTextBoxStyle}"
                                     Text="4" Height="36" FontSize="13" VerticalContentAlignment="Center" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="24,16,24,20">
                <Button Content="取消" Click="Cancel_Click"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="24,8" Margin="0,0,10,0" FontSize="13" />
                <Button Content="保存" Click="Save_Click"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        Padding="24,8" FontSize="13" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
