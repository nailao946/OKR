<Window x:Class="ME.Views.TagEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="管理标签" Height="520" Width="780"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left: Existing Tags List -->
        <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="16">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="现有标签" FontSize="15" FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,12" />
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="TagListPanel" />
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="16" HorizontalAlignment="Stretch" 
                      Background="Transparent" />

        <!-- Right: Create/Edit Form -->
        <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="16">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" x:Name="FormTitle" Text="创建新标签" FontSize="15" FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,12" />
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="标签名称" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,8" />
                            <TextBox x:Name="TagNameBox" Style="{StaticResource InputTextBoxStyle}" 
                                     Height="44" FontSize="15" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="标签颜色" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,10" />
                            <WrapPanel x:Name="ColorPanel">
                                <Border Width="38" Height="38" CornerRadius="19" Background="#FF3B30" Margin="0,0,10,10"
                                        Cursor="Hand" Tag="#FF3B30" MouseLeftButtonDown="Color_Click"
                                        BorderBrush="Transparent" BorderThickness="3" />
                                <Border Width="38" Height="38" CornerRadius="19" Background="#FF9500" Margin="0,0,10,10"
                                        Cursor="Hand" Tag="#FF9500" MouseLeftButtonDown="Color_Click"
                                        BorderBrush="Transparent" BorderThickness="3" />
                                <Border Width="38" Height="38" CornerRadius="19" Background="#FFCC00" Margin="0,0,10,10"
                                        Cursor="Hand" Tag="#FFCC00" MouseLeftButtonDown="Color_Click"
                                        BorderBrush="Transparent" BorderThickness="3" />
                                <Border Width="38" Height="38" CornerRadius="19" Background="#34C759" Margin="0,0,10,10"
                                        Cursor="Hand" Tag="#34C759" MouseLeftButtonDown="Color_Click"
                                        BorderBrush="Transparent" BorderThickness="3" />
                                <Border Width="38" Height="38" CornerRadius="19" Background="#5AC8FA" Margin="0,0,10,10"
                                        Cursor="Hand" Tag="#5AC8FA" MouseLeftButtonDown="Color_Click"
                                        BorderBrush="Transparent" BorderThickness="3" />
                                <Border Width="38" Height="38" CornerRadius="19" Background="#007AFF" Margin="0,0,10,10"
                                        Cursor="Hand" Tag="#007AFF" MouseLeftButtonDown="Color_Click"
                                        BorderBrush="#FFFFFF" BorderThickness="3" />
                                <Border Width="38" Height="38" CornerRadius="19" Background="#5856D6" Margin="0,0,10,10"
                                        Cursor="Hand" Tag="#5856D6" MouseLeftButtonDown="Color_Click"
                                        BorderBrush="Transparent" BorderThickness="3" />
                                <Border Width="38" Height="38" CornerRadius="19" Background="#AF52DE" Margin="0,0,10,10"
                                        Cursor="Hand" Tag="#AF52DE" MouseLeftButtonDown="Color_Click"
                                        BorderBrush="Transparent" BorderThickness="3" />
                                <Border Width="38" Height="38" CornerRadius="19" Background="#FF2D55" Margin="0,0,10,10"
                                        Cursor="Hand" Tag="#FF2D55" MouseLeftButtonDown="Color_Click"
                                        BorderBrush="Transparent" BorderThickness="3" />
                                <Border Width="38" Height="38" CornerRadius="19" Background="#A2845E" Margin="0,0,10,10"
                                        Cursor="Hand" Tag="#A2845E" MouseLeftButtonDown="Color_Click"
                                        BorderBrush="Transparent" BorderThickness="3" />
                                <Border Width="38" Height="38" CornerRadius="19" Background="#8E8E93" Margin="0,0,10,10"
                                        Cursor="Hand" Tag="#8E8E93" MouseLeftButtonDown="Color_Click"
                                        BorderBrush="Transparent" BorderThickness="3" />
                            </WrapPanel>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="自定义颜色" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,8" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="ColorPreview" Grid.Column="0" Width="44" Height="44" CornerRadius="8"
                                        Background="#007AFF" BorderBrush="#FFD1D1D6" BorderThickness="1"
                                        Margin="0,0,10,0" VerticalAlignment="Center" />
                                <TextBox x:Name="CustomColorBox" Grid.Column="1" Style="{StaticResource InputTextBoxStyle}" 
                                         Height="44" FontSize="14" VerticalContentAlignment="Center" />
                                <Button Grid.Column="2" Content="选色" Click="PickColor_Click"
                                        Style="{StaticResource SecondaryButtonStyle}" Padding="12,8" Margin="8,0,0,0" FontSize="12" />
                                <Button Grid.Column="3" Content="应用" Click="ApplyCustomColor_Click"
                                        Style="{StaticResource SecondaryButtonStyle}" Padding="12,8" Margin="8,0,0,0" FontSize="12" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                            <Button x:Name="CancelEditBtn" Content="取消编辑" Style="{StaticResource SecondaryButtonStyle}"
                                    Click="CancelEdit_Click" Padding="24,10" Margin="0,0,12,0" FontSize="14"
                                    Visibility="Collapsed" />
                            <Button Content="保存" Style="{StaticResource PrimaryButtonStyle}"
                                    Click="Save_Click" Padding="32,10" FontSize="14" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</Window>
