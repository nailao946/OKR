<Window x:Class="ME.Views.TagEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False"
        Title="管理标签" Height="480" Width="700">
    <Border CornerRadius="14" Background="{DynamicResource BackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Opacity="0.25" BlurRadius="24" ShadowDepth="2" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" CornerRadius="14,14,0,0" MouseLeftButtonDown="TitleBar_MouseDown"
                    Background="{DynamicResource CardBrush}">
                <Grid Margin="16,0">
                    <TextBlock Text="管理标签" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}"
                               VerticalAlignment="Center" HorizontalAlignment="Left" />
                    <Button Content="✕" Click="Close_Click"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="8,2" FontSize="12"
                            HorizontalAlignment="Right" VerticalAlignment="Center" />
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="16,12,16,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Left: Existing Tags List -->
                <Border Grid.Column="0" Style="{DynamicResource CardStyle}" Padding="14">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="现有标签" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}" Margin="0,0,0,10" />
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="TagListPanel" />
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- Right: Create/Edit Form -->
                <Border Grid.Column="2" Style="{DynamicResource CardStyle}" Padding="14">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" x:Name="FormTitle" Text="创建新标签" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}" Margin="0,0,0,10" />
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="标签名称" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                <TextBox x:Name="TagNameBox" Style="{DynamicResource InputTextBoxStyle}"
                                         Height="40" FontSize="13" Margin="0,0,0,12"
                                         VerticalContentAlignment="Center"
                                         Padding="10,8" />

                                <TextBlock Text="标签颜色" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8" />
                                <WrapPanel x:Name="ColorPanel" Margin="0,0,0,12">
                                    <Border Width="32" Height="32" CornerRadius="16" Background="#FF3B30" Margin="0,0,8,8"
                                            Cursor="Hand" Tag="#FF3B30" MouseLeftButtonDown="Color_Click"
                                            BorderBrush="Transparent" BorderThickness="3" />
                                    <Border Width="32" Height="32" CornerRadius="16" Background="#FF9500" Margin="0,0,8,8"
                                            Cursor="Hand" Tag="#FF9500" MouseLeftButtonDown="Color_Click"
                                            BorderBrush="Transparent" BorderThickness="3" />
                                    <Border Width="32" Height="32" CornerRadius="16" Background="#FFCC00" Margin="0,0,8,8"
                                            Cursor="Hand" Tag="#FFCC00" MouseLeftButtonDown="Color_Click"
                                            BorderBrush="Transparent" BorderThickness="3" />
                                    <Border Width="32" Height="32" CornerRadius="16" Background="#34C759" Margin="0,0,8,8"
                                            Cursor="Hand" Tag="#34C759" MouseLeftButtonDown="Color_Click"
                                            BorderBrush="Transparent" BorderThickness="3" />
                                    <Border Width="32" Height="32" CornerRadius="16" Background="#5AC8FA" Margin="0,0,8,8"
                                            Cursor="Hand" Tag="#5AC8FA" MouseLeftButtonDown="Color_Click"
                                            BorderBrush="Transparent" BorderThickness="3" />
                                    <Border Width="32" Height="32" CornerRadius="16" Background="#007AFF" Margin="0,0,8,8"
                                            Cursor="Hand" Tag="#007AFF" MouseLeftButtonDown="Color_Click"
                                            BorderBrush="#FFFFFF" BorderThickness="3" />
                                    <Border Width="32" Height="32" CornerRadius="16" Background="#5856D6" Margin="0,0,8,8"
                                            Cursor="Hand" Tag="#5856D6" MouseLeftButtonDown="Color_Click"
                                            BorderBrush="Transparent" BorderThickness="3" />
                                    <Border Width="32" Height="32" CornerRadius="16" Background="#AF52DE" Margin="0,0,8,8"
                                            Cursor="Hand" Tag="#AF52DE" MouseLeftButtonDown="Color_Click"
                                            BorderBrush="Transparent" BorderThickness="3" />
                                    <Border Width="32" Height="32" CornerRadius="16" Background="#FF2D55" Margin="0,0,8,8"
                                            Cursor="Hand" Tag="#FF2D55" MouseLeftButtonDown="Color_Click"
                                            BorderBrush="Transparent" BorderThickness="3" />
                                    <Border Width="32" Height="32" CornerRadius="16" Background="#A2845E" Margin="0,0,8,8"
                                            Cursor="Hand" Tag="#A2845E" MouseLeftButtonDown="Color_Click"
                                            BorderBrush="Transparent" BorderThickness="3" />
                                    <Border Width="32" Height="32" CornerRadius="16" Background="#8E8E93" Margin="0,0,8,8"
                                            Cursor="Hand" Tag="#8E8E93" MouseLeftButtonDown="Color_Click"
                                            BorderBrush="Transparent" BorderThickness="3" />
                                </WrapPanel>

                                <TextBlock Text="自定义颜色" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="ColorPreview" Grid.Column="0" Width="36" Height="36" CornerRadius="8"
                                            Background="#007AFF" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                            Margin="0,0,8,0" VerticalAlignment="Center" />
                                    <TextBox x:Name="CustomColorBox" Grid.Column="1" Style="{DynamicResource InputTextBoxStyle}" FontSize="13" VerticalContentAlignment="Center"
                                             Padding="10,8" Height="40" />
                                    <Button Grid.Column="2" Content="选色" Click="PickColor_Click"
                                            Style="{DynamicResource SecondaryButtonStyle}" Padding="10,6" Margin="6,0,0,0" FontSize="11" />
                                    <Button Grid.Column="3" Content="应用" Click="ApplyCustomColor_Click"
                                            Style="{DynamicResource SecondaryButtonStyle}" Padding="10,6" Margin="6,0,0,0" FontSize="11" />
                                </Grid>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                                    <Button x:Name="CancelEditBtn" Content="取消编辑" Style="{DynamicResource SecondaryButtonStyle}"
                                            Click="CancelEdit_Click" Padding="20,8" Margin="0,0,10,0" FontSize="13"
                                            Visibility="Collapsed" />
                                    <Button Content="保存" Style="{DynamicResource PrimaryButtonStyle}"
                                            Click="Save_Click" Padding="28,8" FontSize="13" />
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
