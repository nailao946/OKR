<Window x:Class="ME.Views.RecordEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False"
        Title="编辑记录" Height="300" Width="360">
    <Border CornerRadius="14" Background="{DynamicResource BackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Opacity="0.25" BlurRadius="24" ShadowDepth="2" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" CornerRadius="14,14,0,0" MouseLeftButtonDown="TitleBar_MouseDown"
                    Background="{DynamicResource CardBrush}">
                <Grid Margin="16,0">
                    <TextBlock Text="编辑时间记录" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}"
                               VerticalAlignment="Center" HorizontalAlignment="Left" />
                    <Button Content="✕" Click="Cancel_Click"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="8,2" FontSize="12"
                            HorizontalAlignment="Right" VerticalAlignment="Center" />
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="20,12,20,0">
                <StackPanel>
                    <TextBlock Text="开始时间" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                    <TextBox x:Name="StartTimeBox" Style="{DynamicResource InputTextBoxStyle}"
                             Height="36" FontSize="13" Margin="0,0,0,12" />

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="结束时间" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"
                                   VerticalAlignment="Center" />
                        <CheckBox x:Name="NoEndTimeCheck" Content="无结束时间（进行中）"
                                  FontSize="11" Margin="12,0,0,0" VerticalAlignment="Center"
                                  Foreground="{DynamicResource SecondaryTextBrush}"
                                  Checked="NoEndTime_Changed" Unchecked="NoEndTime_Changed" />
                    </StackPanel>
                    <TextBox x:Name="EndTimeBox" Style="{DynamicResource InputTextBoxStyle}"
                             Height="36" FontSize="13" Margin="0,0,0,12" />

                    <TextBlock Text="标签" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                    <ComboBox x:Name="TagComboBox" FontSize="13" DisplayMemberPath="Name"
                              Style="{StaticResource MacComboBoxStyle}" />
                </StackPanel>
            </ScrollViewer>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,12,20,16">
                <Button Content="取消" Click="Cancel_Click"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Padding="20,8" Margin="0,0,10,0" FontSize="13" />
                <Button Content="保存" Click="Save_Click"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        Padding="20,8" FontSize="13" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
