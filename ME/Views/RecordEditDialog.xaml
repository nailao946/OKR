<Window x:Class="ME.Views.RecordEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
        WindowStartupLocation="CenterOwner" FontFamily="Segoe UI"
        Title="编辑记录" Height="320" Width="380"
        AllowsTransparency="True">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" GlassFrameThickness="0"
                      ResizeBorderThickness="0" UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Border CornerRadius="10" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
        <Border.Effect>
            <DropShadowEffect Opacity="0.3" BlurRadius="20" ShadowDepth="2" />
        </Border.Effect>
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="编辑时间记录" FontSize="16" FontWeight="SemiBold"
                       HorizontalAlignment="Center" Margin="0,0,0,16"
                       Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" />

            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                <TextBlock Text="开始时间" FontSize="12" Margin="0,0,0,4"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                <TextBox x:Name="StartTimeBox" FontSize="12" Padding="6,4"
                         BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                         Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" />

                <StackPanel Orientation="Horizontal" Margin="0,12,0,4">
                    <TextBlock Text="结束时间" FontSize="12" VerticalAlignment="Center"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    <CheckBox x:Name="NoEndTimeCheck" Content="无结束时间（进行中）"
                              FontSize="11" Margin="12,0,0,0" VerticalAlignment="Center"
                              Checked="NoEndTime_Changed" Unchecked="NoEndTime_Changed" />
                </StackPanel>
                <TextBox x:Name="EndTimeBox" FontSize="12" Padding="6,4"
                         BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                         Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" />

                <TextBlock Text="标签" FontSize="12" Margin="0,12,0,4"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                <ComboBox x:Name="TagComboBox" FontSize="12" DisplayMemberPath="Name"
                          Style="{StaticResource MacComboBoxStyle}" />
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="取消" Margin="0,0,8,0"
                        FontSize="12" Padding="12,4" Cursor="Hand" Click="Cancel_Click"
                        Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                        BorderThickness="0"
                        Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" />
                <Button Content="保存"
                        FontSize="12" Padding="12,4" Cursor="Hand" Click="Save_Click"
                        Background="{DynamicResource SystemControlHighlightAccentBrush}"
                        BorderThickness="0" Foreground="White" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
