<UserControl x:Class="ME.Views.CustomDatePicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="36" MinWidth="140">
    <Grid>
        <Border x:Name="DropDownBorder" Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="8" Cursor="Hand" ClipToBounds="True"
                MouseLeftButtonDown="TogglePopup">
            <DockPanel Margin="10,0">
                <TextBlock x:Name="DateText" Text="选择日期" FontSize="13"
                           Foreground="{DynamicResource TextBrush}"
                           VerticalAlignment="Center" />
                <TextBlock DockPanel.Dock="Right" Text="&#xE787;" FontFamily="Segoe MDL2 Assets"
                           FontSize="14" Foreground="{DynamicResource SecondaryTextBrush}"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <Popup x:Name="CalendarPopup" Placement="Bottom" PlacementTarget="{Binding ElementName=DropDownBorder}"
               AllowsTransparency="True" StaysOpen="True" IsOpen="False"
               HorizontalOffset="-20" VerticalOffset="4">
            <Border CornerRadius="12" Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    MinWidth="280" Padding="12"
                    GotMouseCapture="Popup_GotMouseCapture">
                <Border.Effect>
                    <DropShadowEffect Opacity="0.2" BlurRadius="16" ShadowDepth="2" />
                </Border.Effect>
                <StackPanel>
                    <!-- Header: Month/Year + Navigation -->
                    <DockPanel Margin="0,0,0,10">
                        <Button x:Name="PrevMonthBtn" Content="◀" DockPanel.Dock="Left"
                                Click="PrevMonth_Click" Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="8,4" FontSize="11" />
                        <Button x:Name="NextMonthBtn" Content="▶" DockPanel.Dock="Right"
                                Click="NextMonth_Click" Style="{DynamicResource SecondaryButtonStyle}"
                                Padding="8,4" FontSize="11" />
                        <TextBlock x:Name="MonthYearLabel" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </DockPanel>

                    <!-- Day of Week Headers -->
                    <UniformGrid Columns="7" Margin="0,0,0,4">
                        <TextBlock Text="日" TextAlignment="Center" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                        <TextBlock Text="一" TextAlignment="Center" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                        <TextBlock Text="二" TextAlignment="Center" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                        <TextBlock Text="三" TextAlignment="Center" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                        <TextBlock Text="四" TextAlignment="Center" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                        <TextBlock Text="五" TextAlignment="Center" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                        <TextBlock Text="六" TextAlignment="Center" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                    </UniformGrid>

                    <!-- Day Buttons Grid -->
                    <UniformGrid x:Name="DaysGrid" Columns="7" />

                    <!-- Today Button -->
                    <Button Content="今天" Click="Today_Click" Margin="0,8,0,0"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Padding="16,4" FontSize="11" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
