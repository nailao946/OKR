<UserControl x:Class="ME.Views.ReviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <!-- Period Selector -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20" HorizontalAlignment="Center">
                <Button x:Name="WeeklyBtn" Content="本周" Click="Weekly_Click"
                        Style="{StaticResource PrimaryButtonStyle}" Padding="20,8" Margin="0,0,8,0" />
                <Button x:Name="MonthlyBtn" Content="本月" Click="Monthly_Click"
                        Style="{StaticResource SecondaryButtonStyle}" Padding="20,8" />
            </StackPanel>

            <!-- Stats Cards -->
            <UniformGrid Columns="4" Margin="0,0,0,16">
                <Border Style="{StaticResource CardStyle}" Margin="0,0,6,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="完成率" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" HorizontalAlignment="Center" />
                        <TextBlock x:Name="CompletionRateText" Text="0%" FontSize="26" FontWeight="Bold" 
                                   Foreground="{StaticResource AccentGreenBrush}" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" Margin="3,0,3,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="已完成" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" HorizontalAlignment="Center" />
                        <TextBlock x:Name="CompletedCountText" Text="0" FontSize="26" FontWeight="Bold" 
                                   Foreground="{StaticResource AccentBlueBrush}" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" Margin="3,0,3,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="待完成" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" HorizontalAlignment="Center" />
                        <TextBlock x:Name="PendingCountText" Text="0" FontSize="26" FontWeight="Bold" 
                                   Foreground="{StaticResource AccentPinkBrush}" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" Margin="6,0,0,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="打卡次数" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" HorizontalAlignment="Center" />
                        <TextBlock x:Name="CheckinCountText" Text="0" FontSize="26" FontWeight="Bold" 
                                   Foreground="{StaticResource AccentYellowBrush}" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Daily Line Chart -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="每日打卡记录" FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}" Margin="0,0,0,12" />
                    <Border Background="{StaticResource BackgroundBrush}" CornerRadius="8" 
                            Padding="16,12" Height="220">
                        <Grid x:Name="ChartGrid">
                            <Canvas x:Name="ChartCanvas" />
                        </Grid>
                    </Border>
                </DockPanel>
            </Border>

            <!-- Goal Progress -->
            <Border Style="{StaticResource CardStyle}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="目标进度" FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}" Margin="0,0,0,12" />
                    <ItemsControl x:Name="GoalProgressList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextBrush}" />
                                        <ProgressBar Value="{Binding Progress}" Maximum="100" Height="6"
                                                     Margin="0,4,0,0" Background="Transparent"
                                                     Foreground="{StaticResource PrimaryBrush}" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding ProgressText}" FontSize="12"
                                               Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold"
                                               VerticalAlignment="Center" TextAlignment="Right" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
