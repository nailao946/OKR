<UserControl x:Class="ME.Views.ReviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="4">
            <!-- Period Selector -->
            <Border Style="{StaticResource CardStyle}" Padding="16,12" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="定期盘点" FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource TextBrush}" Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="WeeklyBtn" Content="本周" Click="Weekly_Click"
                                Style="{StaticResource PrimaryButtonStyle}" Padding="24,8" Margin="0,0,8,0" />
                        <Button x:Name="MonthlyBtn" Content="本月" Click="Monthly_Click"
                                Style="{StaticResource SecondaryButtonStyle}" Padding="24,8" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Stats Cards -->
            <UniformGrid Columns="4" Margin="0,0,0,12">
                <Border Style="{StaticResource CardStyle}" Margin="0,0,4,0" Padding="12,16">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="📊" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,4" />
                        <TextBlock Text="完成率" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center" />
                        <TextBlock x:Name="CompletionRateText" Text="0%" FontSize="28" FontWeight="Bold" 
                                   Foreground="{DynamicResource AccentGreenBrush}" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" Margin="2,0,2,0" Padding="12,16">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="✅" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,4" />
                        <TextBlock Text="已完成" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center" />
                        <TextBlock x:Name="CompletedCountText" Text="0" FontSize="28" FontWeight="Bold" 
                                   Foreground="{DynamicResource AccentBlueBrush}" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" Margin="2,0,2,0" Padding="12,16">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="⏳" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,4" />
                        <TextBlock Text="待完成" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center" />
                        <TextBlock x:Name="PendingCountText" Text="0" FontSize="28" FontWeight="Bold" 
                                   Foreground="{DynamicResource AccentPinkBrush}" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" Margin="4,0,0,0" Padding="12,16">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="🔥" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,4" />
                        <TextBlock Text="连续打卡" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center" />
                        <TextBlock x:Name="StreakDaysText" Text="0天" FontSize="28" FontWeight="Bold" 
                                   Foreground="{DynamicResource AccentYellowBrush}" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Daily Line Chart -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12" Padding="16">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="每日打卡趋势" FontSize="15" FontWeight="Bold"
                               Foreground="{DynamicResource TextBrush}" Margin="0,0,0,12" />
                    <Border Background="{DynamicResource BackgroundBrush}" CornerRadius="8" 
                            Padding="16,12" Height="240">
                        <Grid x:Name="ChartGrid">
                            <Canvas x:Name="ChartCanvas" />
                        </Grid>
                    </Border>
                </DockPanel>
            </Border>

            <!-- Goal Progress -->
            <Border Style="{StaticResource CardStyle}" Padding="16">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="目标进度" FontSize="15" FontWeight="Bold"
                               Foreground="{DynamicResource TextBrush}" Margin="0,0,0,12" />
                    <ItemsControl x:Name="GoalProgressList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="8" Padding="12,10" Margin="0,0,0,8"
                                        Background="{DynamicResource BackgroundBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="60" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="8" Height="8" CornerRadius="4"
                                                Background="{DynamicResource PrimaryBrush}"
                                                VerticalAlignment="Center" Margin="0,0,10,0" />
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextBrush}" />
                                            <ProgressBar Value="{Binding Progress}" Maximum="100" Height="6"
                                                         Margin="0,4,0,0"
                                                         Background="{DynamicResource BackgroundBrush}"
                                                         Foreground="{DynamicResource PrimaryBrush}" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding ProgressText}" FontSize="12"
                                                   Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" TextAlignment="Right" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
