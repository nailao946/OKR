<UserControl x:Class="ME.Views.TimeTrackView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="TimeTrackView_Loaded"
             IsVisibleChanged="TimeTrackView_IsVisibleChanged">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" MinWidth="400" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="2*" MinWidth="300" MaxWidth="500" />
        </Grid.ColumnDefinitions>

        <!-- Left Panel -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <!-- Clock -->
                <Border Style="{StaticResource CardStyle}" Padding="16,10">
                    <Grid>
                        <TextBlock x:Name="ClockText" Text="00:00:00" FontSize="28"
                                   FontWeight="Medium" HorizontalAlignment="Left"
                                   Foreground="{DynamicResource TextBrush}" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock x:Name="RunningTagText" Text="" FontSize="12"
                                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,8,0" />
                            <Border x:Name="RunningTagDot" Width="8" Height="8" CornerRadius="4"
                                    Background="Transparent" VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Timer Display -->
                <Border Style="{StaticResource CardStyle}" Padding="16,12">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock x:Name="TimerText" Text="00:00:00" FontSize="42"
                                   FontWeight="Bold" TextAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                        <TextBlock x:Name="PomodoroPhaseText" Text="" FontSize="12"
                                   TextAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"
                                   Margin="0,4,0,0" Visibility="Collapsed" />
                        <ProgressBar x:Name="PomodoroProgress" Height="4" Margin="0,6,0,0"
                                     Visibility="Collapsed" />
                    </StackPanel>
                </Border>

                <!-- Pomodoro Controls -->
                <Border Style="{StaticResource CardStyle}" Padding="12,8">
                    <DockPanel>
                        <Button x:Name="PomodoroToggleBtn" DockPanel.Dock="Left" Content="🍅 番茄钟"
                                Click="PomodoroToggle_Click" FontSize="11" Padding="10,4"
                                Style="{StaticResource SecondaryButtonStyle}" VerticalAlignment="Center" />
                        <Button x:Name="PomodoroSettingsBtn" DockPanel.Dock="Left" Content="⚙"
                                Click="PomodoroSettings_Click" FontSize="11" Padding="6,4" Margin="6,0,0,0"
                                Style="{StaticResource SecondaryButtonStyle}" VerticalAlignment="Center"
                                ToolTip="番茄钟设置" Visibility="Collapsed" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock Text="分钟:" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"
                                       VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBox x:Name="MinutesInput" Text="25" Width="40" FontSize="12"
                                     HorizontalContentAlignment="Center" VerticalAlignment="Center"
                                     Style="{StaticResource InputTextBoxStyle}" Padding="4,2" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Tags -->
                <Border Style="{StaticResource CardStyle}" Padding="12,8" MaxHeight="90">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="标签 (点击开始/停止)" FontSize="11" FontWeight="SemiBold"
                                   Margin="0,0,0,6" Foreground="{DynamicResource SecondaryTextBrush}" />
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="TagItemsControl">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- Time Stats -->
                <Border Style="{StaticResource CardStyle}" Padding="12,8">
                    <DockPanel>
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                            <TextBlock Text="时间统计" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SecondaryTextBrush}" DockPanel.Dock="Left" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="StatsDayBtn" Content="日" Click="StatsDay_Click" FontSize="10" Padding="6,2"
                                        Style="{StaticResource PrimaryButtonStyle}" />
                                <Button x:Name="StatsWeekBtn" Content="周" Click="StatsWeek_Click" FontSize="10" Padding="6,2" Margin="4,0,0,0"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                                <Button x:Name="StatsMonthBtn" Content="月" Click="StatsMonth_Click" FontSize="10" Padding="6,2" Margin="4,0,0,0"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                                <Button x:Name="StatsYearBtn" Content="年" Click="StatsYear_Click" FontSize="10" Padding="6,2" Margin="4,0,0,0"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                            </StackPanel>
                        </DockPanel>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="120">
                            <WrapPanel x:Name="TodayStatsPanel" />
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- Gantt Chart -->
                <Border Margin="0,0,0,8">
                    <DockPanel>
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                            <TextBlock Text="甘特图" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SecondaryTextBrush}" />
                            <TextBlock x:Name="GanttDateLabel" FontSize="11"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       HorizontalAlignment="Right" />
                        </DockPanel>
                        <Border x:Name="GanttChartBorder" Style="{StaticResource CardStyle}" Padding="8"
                                SizeChanged="GanttBorder_SizeChanged">
                            <Canvas x:Name="GanttCanvas" MinHeight="120" />
                        </Border>
                    </DockPanel>
                </Border>

                <!-- Gantt Detail Popup -->
                <Popup x:Name="GanttDetailPopup" Placement="Center" PlacementTarget="{Binding ElementName=GanttChartBorder}"
                       AllowsTransparency="True" StaysOpen="False" IsOpen="False">
                    <Border CornerRadius="14" Background="{DynamicResource BackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            MinWidth="320" MaxWidth="500" MaxHeight="500"
                            Margin="0,0,0,0">
                        <Border.Effect>
                            <DropShadowEffect Opacity="0.25" BlurRadius="24" ShadowDepth="2" />
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="44" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" CornerRadius="14,14,0,0" MouseLeftButtonDown="DetailTitleBar_MouseDown"
                                    Background="{DynamicResource CardBrush}">
                                <Grid Margin="16,0">
                                    <StackPanel x:Name="DetailTitlePanel" Orientation="Horizontal" VerticalAlignment="Center" />
                                    <Button Content="✕" Click="GanttDetail_Close"
                                            Style="{DynamicResource SecondaryButtonStyle}"
                                            Padding="8,2" FontSize="12"
                                            HorizontalAlignment="Right" VerticalAlignment="Center" />
                                </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="440" Margin="16,12,16,16">
                                <StackPanel x:Name="GanttDetailContent" />
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Popup>

                <!-- Pie Charts: Weekly + Monthly -->
                <Border Style="{StaticResource CardStyle}" Padding="12,8" Margin="0,0,0,8">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="标签用时分布" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Text="本周" FontSize="10" Foreground="{DynamicResource SecondaryTextBrush}"
                                           HorizontalAlignment="Center" Margin="0,0,0,4" />
                                <Canvas x:Name="WeekPieCanvas" Width="120" Height="120" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Text="本月" FontSize="10" Foreground="{DynamicResource SecondaryTextBrush}"
                                           HorizontalAlignment="Center" Margin="0,0,0,4" />
                                <Canvas x:Name="MonthPieCanvas" Width="120" Height="120" />
                            </StackPanel>
                        </Grid>
                    </DockPanel>
                </Border>

                <!-- Bottom Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,8">
                    <Button Content="＋标签" Click="AddTag_Click" Padding="10,5" FontSize="11"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    <Button Content="导出CSV" Click="ExportCsv_Click" Padding="10,5" FontSize="11"
                            Margin="6,0,0,0" Style="{StaticResource SecondaryButtonStyle}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch"
                      Background="Transparent" />

        <!-- Right Panel: Calendar + Records -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Calendar -->
            <Border Grid.Row="0" Style="{StaticResource CardStyle}" Padding="10" Margin="0,0,0,8">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                        <Button Content="◀" Click="PrevMonth_Click" DockPanel.Dock="Left"
                                Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" />
                        <Button Content="▶" Click="NextMonth_Click" DockPanel.Dock="Right"
                                Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" />
                        <TextBlock x:Name="MonthLabel" FontSize="16" FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextBrush}" />
                    </DockPanel>

                    <UniformGrid DockPanel.Dock="Top" Columns="7" Margin="0,0,0,6">
                        <TextBlock Text="日" TextAlignment="Center" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                        <TextBlock Text="一" TextAlignment="Center" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                        <TextBlock Text="二" TextAlignment="Center" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                        <TextBlock Text="三" TextAlignment="Center" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                        <TextBlock Text="四" TextAlignment="Center" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                        <TextBlock Text="五" TextAlignment="Center" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                        <TextBlock Text="六" TextAlignment="Center" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                    </UniformGrid>

                    <UniformGrid x:Name="CalendarGrid" Columns="7" />
                </DockPanel>
            </Border>

            <!-- Time Records under Calendar -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="10">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <TextBlock Text="时间记录" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}" />
                        <Button x:Name="ClearRecordsBtn" Content="清空" Click="ClearRecords_Click"
                                Padding="8,3" FontSize="11" HorizontalAlignment="Right"
                                Style="{StaticResource SecondaryButtonStyle}" />
                    </DockPanel>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="RecordsPanel" />
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
