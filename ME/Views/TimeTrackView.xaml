<UserControl x:Class="ME.Views.TimeTrackView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="TimeTrackView_Loaded"
             IsVisibleChanged="TimeTrackView_IsVisibleChanged">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" MinWidth="400" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="1*" MinWidth="240" MaxWidth="360" />
        </Grid.ColumnDefinitions>

        <!-- Left Panel -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Row 0: Digital Clock -->
            <TextBlock x:Name="ClockText" Grid.Row="0" Text="00:00:00" FontSize="32"
                       FontWeight="Medium" TextAlignment="Center" Margin="0,8,0,0"
                       Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" />

            <!-- Row 1: Timer Display -->
            <TextBlock x:Name="TimerText" Grid.Row="1" Text="00:00:00" FontSize="36"
                       FontWeight="Bold" TextAlignment="Center" Margin="0,4,0,0"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />

            <!-- Row 2: Mode Switch -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                <RadioButton x:Name="CountUpRadio" Content="正计时" IsChecked="True"
                             Checked="CountUpRadio_Checked" Margin="0,0,16,0"
                             Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" />
                <RadioButton x:Name="CountDownRadio" Content="倒计时"
                             Checked="CountDownRadio_Checked"
                             Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" />
            </StackPanel>

            <!-- Row 3: Tags -->
            <Border Grid.Row="3" Margin="0,8,0,0" MaxHeight="80">
                <ItemsControl x:Name="TagItemsControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </Border>

            <!-- Row 4: Records -->
            <Border Grid.Row="4" Margin="0,8,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="时间记录" FontSize="12" FontWeight="SemiBold"
                               Margin="0,0,0,8"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="RecordsPanel" />
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Row 5: Bottom Buttons -->
            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                <Button Content="＋添加标签" Click="AddTag_Click" Padding="10,5" FontSize="12"
                        Style="{StaticResource SecondaryButtonStyle}" />
                <Button Content="导出CSV" Click="ExportCsv_Click" Padding="10,5" FontSize="12"
                        Margin="6,0,0,0" Style="{StaticResource SecondaryButtonStyle}" />
                <Button Content="清空记录" Click="ClearRecords_Click" Padding="10,5" FontSize="12"
                        Margin="6,0,0,0" Style="{StaticResource SecondaryButtonStyle}" />
            </StackPanel>
        </Grid>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch"
                      Background="Transparent" />

        <!-- Right Panel: Calendar -->
        <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="10">
            <DockPanel>
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                    <Button Content="◀" Click="PrevMonth_Click" DockPanel.Dock="Left"
                            Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" />
                    <Button Content="▶" Click="NextMonth_Click" DockPanel.Dock="Right"
                            Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" />
                    <TextBlock x:Name="MonthLabel" FontSize="16" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" />
                </DockPanel>

                <UniformGrid DockPanel.Dock="Top" Columns="7" Margin="0,0,0,6">
                    <TextBlock Text="日" TextAlignment="Center" FontWeight="SemiBold"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    <TextBlock Text="一" TextAlignment="Center" FontWeight="SemiBold"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    <TextBlock Text="二" TextAlignment="Center" FontWeight="SemiBold"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    <TextBlock Text="三" TextAlignment="Center" FontWeight="SemiBold"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    <TextBlock Text="四" TextAlignment="Center" FontWeight="SemiBold"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    <TextBlock Text="五" TextAlignment="Center" FontWeight="SemiBold"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    <TextBlock Text="六" TextAlignment="Center" FontWeight="SemiBold"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                </UniformGrid>

                <UniformGrid x:Name="CalendarGrid" Columns="7" />
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
