<UserControl x:Class="ME.Views.GoalsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:ME.Converters"
             IsVisibleChanged="GoalsView_IsVisibleChanged">
    <UserControl.Resources>
        <converters:GoalTagColorConverter x:Key="TagColorConverter" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <Button Content="+ 新建目标" Click="AddGoal_Click"
                    Style="{StaticResource PrimaryButtonStyle}" Padding="20,10"
                    DockPanel.Dock="Right" />
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" Margin="0,0,16,0">
                <Button x:Name="TagManageBtn" Content="管理标签" Click="ManageTags_Click"
                        Style="{StaticResource SecondaryButtonStyle}" Padding="12,8" FontSize="12" />
            </StackPanel>
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                          Margin="0,0,8,0">
                <StackPanel x:Name="TagFilterPanel" Orientation="Horizontal" />
            </ScrollViewer>
        </DockPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Expander x:Name="IncompleteExpander" IsExpanded="True" Margin="0,0,0,8">
                    <Expander.Header>
                        <TextBlock Text="未完成" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}" />
                    </Expander.Header>
                    <StackPanel x:Name="IncompleteGoalsPanel" />
                </Expander>
                <Expander x:Name="CompletedExpander" IsExpanded="False" Margin="0,8,0,0">
                    <Expander.Header>
                        <TextBlock Text="已完成" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource SecondaryTextBrush}" />
                    </Expander.Header>
                    <StackPanel x:Name="CompletedGoalsPanel" />
                </Expander>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
