<UserControl x:Class="ME.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <!-- System Settings -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="系统设置" FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}" Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <CheckBox x:Name="AutoStartToggle" Checked="AutoStartToggle_Changed" Unchecked="AutoStartToggle_Changed"
                                  VerticalAlignment="Center" />
                        <TextBlock Text="开机自动启动" Foreground="{StaticResource TextBrush}" FontSize="13"
                                   VerticalAlignment="Center" Margin="8,0,0,0" />
                    </StackPanel>
                    <TextBlock Text="Windows启动时自动运行目标地图" FontSize="11"
                               Foreground="{StaticResource SecondaryTextBrush}" Margin="24,0,0,0" />
                </StackPanel>
            </Border>

            <!-- Sound Settings -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="音效设置" FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}" Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <CheckBox x:Name="SoundToggle" Checked="SoundToggle_Changed" Unchecked="SoundToggle_Changed"
                                  VerticalAlignment="Center" />
                        <TextBlock Text="启用完成音效" Foreground="{StaticResource TextBrush}" FontSize="13"
                                   VerticalAlignment="Center" Margin="8,0,0,0" />
                    </StackPanel>
                    <TextBlock Text="完成或取消完成任务时播放提示音" FontSize="11"
                               Foreground="{StaticResource SecondaryTextBrush}" Margin="24,0,0,0" />
                </StackPanel>
            </Border>

            <!-- Data Backup -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="数据备份" FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}" Margin="0,0,0,12" />
                    
                    <!-- Backup Mode Selection -->
                    <TextBlock Text="备份模式" FontSize="13" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <RadioButton x:Name="BackupModePartial" Content="单独备份" GroupName="BackupMode" 
                                     Checked="BackupMode_Changed" VerticalAlignment="Center" Margin="0,0,16,0" />
                        <RadioButton x:Name="BackupModeFull" Content="全部备份" GroupName="BackupMode" 
                                     Checked="BackupMode_Changed" VerticalAlignment="Center" />
                    </StackPanel>
                    
                    <!-- Partial Backup Options -->
                    <StackPanel x:Name="PartialBackupPanel" Margin="0,0,0,12">
                        <TextBlock Text="选择要备份的数据" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,8" />
                        <WrapPanel>
                            <CheckBox x:Name="BackupGoals" Content="目标" IsChecked="True" Margin="0,0,12,6" />
                            <CheckBox x:Name="BackupTasks" Content="任务" IsChecked="True" Margin="0,0,12,6" />
                            <CheckBox x:Name="BackupVisions" Content="愿景" IsChecked="True" Margin="0,0,12,6" />
                            <CheckBox x:Name="BackupReviews" Content="复盘" IsChecked="True" Margin="0,0,12,6" />
                            <CheckBox x:Name="BackupFocus" Content="专注" IsChecked="True" Margin="0,0,12,6" />
                            <CheckBox x:Name="BackupSettings" Content="设置" IsChecked="True" Margin="0,0,12,6" />
                            <CheckBox x:Name="BackupTags" Content="标签" IsChecked="True" Margin="0,0,12,6" />
                        </WrapPanel>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="BackupBtn" Content="备份" Click="Backup_Click"
                                Style="{StaticResource PrimaryButtonStyle}" Padding="16,8" Margin="0,0,8,0" />
                        <Button Content="导入" Click="Restore_Click"
                                Style="{StaticResource SecondaryButtonStyle}" Padding="16,8" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- About -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="关于目标地图" FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}" Margin="0,0,0,8" />
                    <TextBlock Text="版本 1.0.0" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" />
                    <TextBlock Text="纯本地离线运行，保护您的隐私数据安全" FontSize="12"
                               Foreground="{StaticResource SecondaryTextBrush}" Margin="0,4,0,0" />
                    <TextBlock Text="基于 .NET WPF 开发" FontSize="12"
                               Foreground="{StaticResource SecondaryTextBrush}" Margin="0,4,0,0" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
