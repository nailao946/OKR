<UserControl x:Class="ME.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             IsVisibleChanged="DashboardView_IsVisibleChanged">
    <Grid Margin="4">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left: Task List with Tag Filter -->
        <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="12">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="任务列表" FontSize="15" FontWeight="Bold"
                           Foreground="{DynamicResource TextBrush}" Margin="0,0,0,6" />
                <!-- Tag filter -->
                <ScrollViewer DockPanel.Dock="Top" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                              Margin="0,0,0,8">
                    <StackPanel x:Name="TagFilterPanel" Orientation="Horizontal" />
                </ScrollViewer>
                <ListBox x:Name="TaskListBox" SelectionMode="Single"
                         SelectionChanged="TaskListBox_SelectionChanged"
                         Style="{StaticResource MacListBoxStyle}">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                            <Setter Property="Padding" Value="8,6" />
                            <Setter Property="Margin" Value="0,2" />
                            <Setter Property="HorizontalContentAlignment" Value="Left" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                                CornerRadius="6" Padding="{TemplateBinding Padding}"
                                                BorderThickness="1.5" BorderBrush="Transparent">
                                            <ContentPresenter HorizontalAlignment="Left" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource NavHoverBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource NavSelectedBrush}" />
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                                                <Setter Property="Foreground" Value="White" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="4,4" HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                    <Border CornerRadius="3" Padding="5,1" Margin="0,0,6,0"
                                            Background="{Binding TagColorBrush}" Visibility="{Binding TagVisibility}">
                                        <TextBlock Text="{Binding TagName}" FontSize="9" Foreground="White" />
                                    </Border>
                                    <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}" />
                                </StackPanel>
                                <TextBlock Text="{Binding Description}" FontSize="10"
                                           Foreground="{DynamicResource SecondaryTextBrush}" 
                                           TextTrimming="CharacterEllipsis" MaxHeight="30"
                                           HorizontalAlignment="Left" Margin="0,2,0,0" />
                                <TextBlock Text="{Binding TypeText}" FontSize="10"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           HorizontalAlignment="Left" Margin="0,2,0,0" />
                                <StackPanel Visibility="{Binding ProgressVisibility}" Margin="0,4,0,0"
                                            HorizontalAlignment="Left">
                                    <ProgressBar Value="{Binding ProgressValue}" Maximum="100" Height="40"
                                                 Background="{DynamicResource BackgroundBrush}" 
                                                 Foreground="{Binding ProgressBrush}" />
                                    <TextBlock Text="{Binding ProgressText}" FontSize="9" FontWeight="SemiBold"
                                               Foreground="{Binding ProgressBrush}" Margin="0,2,0,0"
                                               HorizontalAlignment="Left" />
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Right: Calendar and Stats -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Stats Cards -->
            <UniformGrid Grid.Row="0" Columns="3">
                <Border Style="{StaticResource CardStyle}" Margin="0,0,4,0" Padding="12,14">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="📊" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,2" />
                        <TextBlock Text="打卡率" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center" />
                        <TextBlock x:Name="CheckInRateText" Text="0%" FontSize="26" FontWeight="Bold" 
                                   Foreground="{DynamicResource PrimaryBrush}" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" Margin="2,0,2,0" Padding="12,14">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="📅" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,2" />
                        <TextBlock Text="剩余天数" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center" />
                        <TextBlock x:Name="RemainingDaysText" Text="0" FontSize="26" FontWeight="Bold" 
                                   Foreground="{DynamicResource AccentBlueBrush}" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" Margin="4,0,0,0" Padding="12,14">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="🔥" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,2" />
                        <TextBlock Text="连续打卡" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center" />
                        <TextBlock x:Name="StreakDaysText" Text="0天" FontSize="26" FontWeight="Bold" 
                                   Foreground="{DynamicResource AccentGreenBrush}" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Calendar -->
            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="12">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                        <Button Content="◀" Click="PrevMonth_Click" Style="{StaticResource SecondaryButtonStyle}" 
                                Padding="8,4" DockPanel.Dock="Left" FontSize="12" />
                        <Button Content="▶" Click="NextMonth_Click" Style="{StaticResource SecondaryButtonStyle}" 
                                Padding="8,4" DockPanel.Dock="Right" FontSize="12" />
                        <TextBlock x:Name="MonthTitle" FontSize="15" FontWeight="Bold"
                                   Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </DockPanel>

                    <UniformGrid DockPanel.Dock="Top" Columns="7" Margin="0,0,0,6">
                        <TextBlock Text="一" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center" />
                        <TextBlock Text="二" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center" />
                        <TextBlock Text="三" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center" />
                        <TextBlock Text="四" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center" />
                        <TextBlock Text="五" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center" />
                        <TextBlock Text="六" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center" />
                        <TextBlock Text="日" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center" />
                    </UniformGrid>

                    <ItemsControl x:Name="CalendarGrid">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="7" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="2" Cursor="Hand" MouseLeftButtonDown="Day_Click">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Border Width="34" Height="34" CornerRadius="17" 
                                                Background="{Binding BackgroundBrush}"
                                                BorderBrush="{Binding BorderBrush}"
                                                BorderThickness="1">
                                            <TextBlock Text="{Binding Day}" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{Binding ForegroundBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
