<UserControl x:Class="ME.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             IsVisibleChanged="DashboardView_IsVisibleChanged">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left: Task List -->
        <Border Grid.Column="0" Style="{StaticResource CardStyle}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="任务列表" FontSize="16" FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,12" />
                <ListBox x:Name="TaskListBox" SelectionMode="Single"
                         SelectionChanged="TaskListBox_SelectionChanged"
                         Style="{StaticResource MacListBoxStyle}">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource MacListBoxItemStyle}">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="4,4" HorizontalAlignment="Stretch">
                                <!-- Tag badge + Title -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                    <Border CornerRadius="3" Padding="5,1" Margin="0,0,6,0"
                                            Background="{Binding TagColorBrush}" Visibility="{Binding TagVisibility}">
                                        <TextBlock Text="{Binding TagName}" FontSize="9" Foreground="White" />
                                    </Border>
                                    <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}" />
                                </StackPanel>
                                <TextBlock Text="{Binding Description}" FontSize="10"
                                           Foreground="{StaticResource SecondaryTextBrush}" 
                                           TextTrimming="CharacterEllipsis" MaxHeight="30"
                                           HorizontalAlignment="Left" Margin="0,2,0,0" />
                                <TextBlock Text="{Binding TypeText}" FontSize="10"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           HorizontalAlignment="Left" Margin="0,2,0,0" />
                                <!-- Progress bar for quantitative and custom recurring tasks -->
                                <StackPanel x:Name="ProgressPanel" Visibility="{Binding ProgressVisibility}" Margin="0,4,0,0">
                                    <ProgressBar Value="{Binding ProgressValue}" Maximum="100" Height="6"
                                                 Background="{StaticResource BackgroundBrush}" 
                                                 Foreground="{Binding ProgressBrush}" />
                                    <TextBlock Text="{Binding ProgressText}" FontSize="9" FontWeight="SemiBold"
                                               Foreground="{Binding ProgressBrush}" Margin="0,2,0,0"
                                               HorizontalAlignment="Left" />
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Right: Calendar and Stats -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Stats Cards -->
            <UniformGrid Grid.Row="0" Columns="3">
                <Border Style="{StaticResource CardStyle}" Margin="0,0,6,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="打卡率" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" HorizontalAlignment="Center" />
                        <TextBlock x:Name="CheckInRateText" Text="0%" FontSize="28" FontWeight="Bold" 
                                   Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" Margin="3,0,3,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="剩余天数" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" HorizontalAlignment="Center" />
                        <TextBlock x:Name="RemainingDaysText" Text="0" FontSize="28" FontWeight="Bold" 
                                   Foreground="{StaticResource AccentBlueBrush}" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" Margin="6,0,0,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="连续打卡" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" HorizontalAlignment="Center" />
                        <TextBlock x:Name="StreakDaysText" Text="0天" FontSize="28" FontWeight="Bold" 
                                   Foreground="{StaticResource AccentGreenBrush}" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Calendar -->
            <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                <DockPanel>
                    <!-- Month Navigation -->
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                        <Button Content="◀" Click="PrevMonth_Click" Style="{StaticResource SecondaryButtonStyle}" 
                                Padding="8,4" DockPanel.Dock="Left" FontSize="12" />
                        <Button Content="▶" Click="NextMonth_Click" Style="{StaticResource SecondaryButtonStyle}" 
                                Padding="8,4" DockPanel.Dock="Right" FontSize="12" />
                        <TextBlock x:Name="MonthTitle" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </DockPanel>

                    <!-- Weekday Headers -->
                    <UniformGrid DockPanel.Dock="Top" Columns="7" Margin="0,0,0,8">
                        <TextBlock Text="一" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" HorizontalAlignment="Center" />
                        <TextBlock Text="二" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" HorizontalAlignment="Center" />
                        <TextBlock Text="三" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" HorizontalAlignment="Center" />
                        <TextBlock Text="四" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" HorizontalAlignment="Center" />
                        <TextBlock Text="五" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" HorizontalAlignment="Center" />
                        <TextBlock Text="六" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" HorizontalAlignment="Center" />
                        <TextBlock Text="日" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" HorizontalAlignment="Center" />
                    </UniformGrid>

                    <!-- Calendar Grid -->
                    <ItemsControl x:Name="CalendarGrid">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="7" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="2" Cursor="Hand" MouseLeftButtonDown="Day_Click">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <!-- Day Circle -->
                                        <Border Width="36" Height="36" CornerRadius="18" 
                                                Background="{Binding BackgroundBrush}"
                                                BorderBrush="{Binding BorderBrush}"
                                                BorderThickness="1">
                                            <TextBlock Text="{Binding Day}" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{Binding ForegroundBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
